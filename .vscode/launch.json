{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug com LLDB",
            "type": "lldb",
            "request": "launch",

            "program": "${workspaceFolder}/app.out",

            "args": [
                "-f", "Artificial_POP_Instance_04.dat",
                "-MIN_PRIZE", "3000",
                "-MIN_PROB", "0.5",
                "-K", "2",
                "-T", "10",
                "-maxNotImproviment", "3000",
                "-seed", "13",
                "-TMAX", "10"
            ],

            "cwd": "${workspaceFolder}",

            "preLaunchTask": "build_debug",

            "terminal": "integrated"
        }
    ]
}